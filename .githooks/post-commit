#!/usr/bin/env python3
import sys
import subprocess
import json
import urllib.request

# ==================== 🛠️ MATCH YOUR MONDAY COLUMN IDS HERE ====================
COLUMN_IDS = {
    "engineer": "person",       
    "date": "date4",            
    "description": "text_mm479zh2", 
    "type": "status",           
    "commit_link": "link_mm47favx"   
}
# ==============================================================================

# 1. Fetch credentials from local Git config
try:
    token = subprocess.check_output(['git', 'config', 'monday.token'], stderr=subprocess.DEVNULL).decode('utf-8').strip()
    board_id = subprocess.check_output(['git', 'config', 'monday.boardid'], stderr=subprocess.DEVNULL).decode('utf-8').strip()
    user_id = subprocess.check_output(['git', 'config', 'monday.userid'], stderr=subprocess.DEVNULL).decode('utf-8').strip()
except subprocess.CalledProcessError:
    token, board_id, user_id = "", "", ""

if not token or not board_id:
    print("⚠️ Monday.com integration skipped: Missing local git config settings.")
    sys.exit(0)

# 2. Extract commit details
subject = subprocess.check_output(['git', 'log', '-1', '--pretty=%s']).decode('utf-8').strip()
body = subprocess.check_output(['git', 'log', '-1', '--pretty=%b']).decode('utf-8').strip()
commit_hash = subprocess.check_output(['git', 'log', '-1', '--pretty=%h']).decode('utf-8').strip()

commit_date = subprocess.check_output(['git', 'log', '-1', "--pretty=%ad", "--date=format:%Y-%m-%d"]).decode('utf-8').strip()
commit_time = subprocess.check_output(['git', 'log', '-1', "--pretty=%ad", "--date=format:%H:%M:%S"]).decode('utf-8').strip()

# 3. Automatically build the repository web link
commit_url = "https://github.com"
try:
    remote_url = subprocess.check_output(['git', 'config', '--get', 'remote.origin.url'], stderr=subprocess.DEVNULL).decode('utf-8').strip()
    if remote_url.startswith("git@"):
        remote_url = remote_url.replace(":", "/").replace("git@", "https://")
    if remote_url.endswith(".git"):
        remote_url = remote_url[:-4]
    
    commit_url = f"{remote_url}/commit/{commit_hash}"
except:
    pass

# 4. Determine the Type label
type_label = ""
if subject.startswith("feat:"): type_label = "Feature"
elif subject.startswith("fix:"): type_label = "Fix"
elif subject.startswith("update:"): type_label = "Update"
elif subject.startswith("refactor:"): type_label = "Refactor"

# 5. Map data to the verified Monday columns
column_values = {
    COLUMN_IDS["description"]: body if body else "",  # 😎 Fixed: Sending a clean, plain text string
    COLUMN_IDS["date"]: {"date": commit_date, "time": commit_time},
    COLUMN_IDS["commit_link"]: {"url": commit_url, "text": commit_hash}
}

# Format assignment for Monday's Person column
if user_id.isdigit():
    column_values[COLUMN_IDS["engineer"]] = {"personsAndTeams": [{"id": int(user_id), "kind": "person"}]}

if type_label:
    column_values[COLUMN_IDS["type"]] = {"label": type_label}

# 6. Build and send GraphQL payload
query = "mutation CreateGitItem($boardId: ID!, $itemName: String!, $columnValues: JSON!) { create_item (board_id: $boardId, item_name: $itemName, column_values: $columnValues) { id } }"
payload = {
    "query": query,
    "variables": {
        "boardId": board_id,
        "itemName": subject,
        "columnValues": json.dumps(column_values)
    }
}

req = urllib.request.Request(
    "https://api.monday.com/v2",
    data=json.dumps(payload).encode('utf-8'),
    headers={"Authorization": token, "Content-Type": "application/json", "API-Version": "2023-10"},
    method="POST"
)

try:
    with urllib.request.urlopen(req) as response:
        output = response.read().decode('utf-8')
        print(f"👉 Monday API Response: {output}")
except Exception as e:
    print(f"❌ Failed to connect to Monday: {e}")